# claude-remote server environment variables

# 서버 포트 (기본: 3001)
PORT=3001

# 웹 클라이언트 포트 (QR 코드 생성 시 사용, 기본: 5188)
WEB_PORT=5188

# 머신 레이블 (서버 선택 화면에 표시, 기본: hostname)
MACHINE_LABEL=My Mac

# GitHub Personal Access Token (Fine-grained)
# 필수 권한: Repository → Administration: Read & Write
# 없으면 GitHub Projects 화면에서 레포 목록만 보이고, 레포 생성 불가
GITHUB_TOKEN=

# 프로젝트 기본 경로 (기본: ~/Desktop/Projects)
# PROJECTS_BASE=/Users/yourname/Projects

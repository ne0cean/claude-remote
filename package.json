{
  "name": "claude-remote",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "server": "bun run --cwd packages/server dev",
    "web": "bun run --cwd packages/web dev",
    "build": "bun run --cwd packages/server build && bun run --cwd packages/web build",
    "dev": "concurrently \"bun run server\" \"bun run web\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
